{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jwd-admin-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-30",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "jwd-portfolio-assets"
    }
  ]
}
